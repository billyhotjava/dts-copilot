<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.22.xsd">

    <changeSet id="0014-001-public-links" author="codex">
        <createTable tableName="analytics_public_link">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="model" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="model_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="public_uuid" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="creator_id" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="analytics_public_link" columnNames="public_uuid" constraintName="ux_analytics_public_link__public_uuid"/>
        <addUniqueConstraint tableName="analytics_public_link" columnNames="model,model_id" constraintName="ux_analytics_public_link__model_model_id"/>

        <addForeignKeyConstraint
            baseTableName="analytics_public_link"
            baseColumnNames="creator_id"
            referencedTableName="analytics_user"
            referencedColumnNames="id"
            constraintName="fk_analytics_public_link__creator"/>
    </changeSet>

</databaseChangeLog>

