<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.22.xsd">

    <changeSet id="0054-promote-pending-fixed-reports" author="dts">
        <update tableName="analytics_report_template">
            <column name="name" value="采购计划待处理"/>
            <column name="description" value="对齐现网页面“采购计划明细”的实时固定报表，按项目、采购人与报花单号查看待采购清单。"/>
            <column name="category" value="待办"/>
            <column name="data_source_type" value="SQL"/>
            <column name="target_object" value="authority.procurement.request_todo"/>
            <column name="refresh_policy" value="REALTIME"/>
            <column name="spec_json"><![CDATA[{
  "templateCode":"PROC-PURCHASE-REQUEST-TODO",
  "reportType":"fixed",
  "displayType":"todo-list",
  "queryContract":{
    "sourceType":"AUTHORITY_SQL",
    "targetObject":"authority.procurement.request_todo"
  },
  "placeholderReviewRequired":false
}]]></column>
            <column name="parameter_schema_json"><![CDATA[{
  "params":[
    {"name":"status","type":"select","label":"状态","options":[{"label":"待采购","value":"1"},{"label":"已采购","value":"2"},{"label":"已配送","value":"3"},{"label":"已作废","value":"-1"}]},
    {"name":"projectId","type":"string","label":"项目点"},
    {"name":"purchaseUserId","type":"string","label":"采购人"},
    {"name":"flowerCode","type":"string","label":"报花单号"},
    {"name":"goodName","type":"string","label":"采购物品"}
  ]
}]]></column>
            <column name="metric_definition_json"><![CDATA[{
  "metrics":["采购数量","已采购数量"],
  "grain":"采购计划明细",
  "owner":"采购负责人"
}]]></column>
            <column name="presentation_schema_json"><![CDATA[{
  "primary":"todo",
  "secondary":"table",
  "layout":"procurement-request-todo"
}]]></column>
            <where>template_code = 'PROC-PURCHASE-REQUEST-TODO'</where>
        </update>

