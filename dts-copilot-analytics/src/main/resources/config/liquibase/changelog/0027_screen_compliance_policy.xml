<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.22.xsd">

    <changeSet id="0027-create-screen-compliance-policy" author="dts">
        <createTable tableName="analytics_screen_compliance_policy">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="version_no" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="policy_json" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="updated_by" type="varchar(128)"/>
            <column name="is_current" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="analytics_screen_compliance_policy" indexName="idx_screen_compliance_policy_current">
            <column name="is_current"/>
            <column name="version_no"/>
        </createIndex>

        <createIndex tableName="analytics_screen_compliance_policy" indexName="idx_screen_compliance_policy_version">
            <column name="version_no"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
