<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.22.xsd">

    <changeSet id="0004-01" author="codex">
        <createTable tableName="analytics_collection">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="entity_id" type="varchar(32)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>
            <column name="archived" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="color" type="varchar(16)"/>
            <column name="slug" type="varchar(255)"/>
            <column name="namespace" type="varchar(64)"/>
            <column name="location" type="varchar(512)" defaultValue="/">
                <constraints nullable="false"/>
            </column>
            <column name="parent_id" type="bigint"/>
            <column name="personal_owner_id" type="bigint"/>
            <column name="created_at" type="timestamp" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="analytics_collection"
            baseColumnNames="parent_id"
            referencedTableName="analytics_collection"
            referencedColumnNames="id"
            constraintName="fk_collection_parent"/>

        <addForeignKeyConstraint
            baseTableName="analytics_collection"
            baseColumnNames="personal_owner_id"
            referencedTableName="analytics_user"
            referencedColumnNames="id"
            constraintName="fk_collection_personal_owner"/>
    </changeSet>

    <changeSet id="0004-02" author="codex">
        <createTable tableName="analytics_card">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="entity_id" type="varchar(32)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>
            <column name="archived" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="collection_id" type="bigint"/>
            <column name="database_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="dataset_query_json" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="display" type="varchar(64)"/>
            <column name="visualization_settings_json" type="text"/>
            <column name="creator_id" type="bigint"/>
            <column name="created_at" type="timestamp" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="analytics_card"
            baseColumnNames="collection_id"
            referencedTableName="analytics_collection"
            referencedColumnNames="id"
            constraintName="fk_card_collection"/>

        <addForeignKeyConstraint
            baseTableName="analytics_card"
            baseColumnNames="database_id"
            referencedTableName="analytics_database"
            referencedColumnNames="id"
            constraintName="fk_card_database"/>

        <addForeignKeyConstraint
            baseTableName="analytics_card"
            baseColumnNames="creator_id"
            referencedTableName="analytics_user"
            referencedColumnNames="id"
            constraintName="fk_card_creator"/>
    </changeSet>
</databaseChangeLog>

