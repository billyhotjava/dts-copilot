<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.22.xsd">

    <changeSet id="0001-01" author="codex">
        <createTable tableName="analytics_setting">
            <column name="setting_key" type="varchar(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="setting_value" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <insert tableName="analytics_setting">
            <column name="setting_key" value="setup_completed"/>
            <column name="setting_value" value="false"/>
        </insert>
    </changeSet>
</databaseChangeLog>
