<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.22.xsd">

    <changeSet id="0005-01" author="codex">
        <createTable tableName="analytics_dashboard">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="entity_id" type="varchar(32)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>
            <column name="archived" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="collection_id" type="bigint"/>
            <column name="creator_id" type="bigint"/>
            <column name="parameters_json" type="text"/>
            <column name="created_at" type="timestamp" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="analytics_dashboard"
            baseColumnNames="collection_id"
            referencedTableName="analytics_collection"
            referencedColumnNames="id"
            constraintName="fk_dashboard_collection"/>

        <addForeignKeyConstraint
            baseTableName="analytics_dashboard"
            baseColumnNames="creator_id"
            referencedTableName="analytics_user"
            referencedColumnNames="id"
            constraintName="fk_dashboard_creator"/>
    </changeSet>

    <changeSet id="0005-02" author="codex">
        <createTable tableName="analytics_dashboard_card">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="dashboard_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="card_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="row" type="int"/>
            <column name="col" type="int"/>
            <column name="size_x" type="int"/>
            <column name="size_y" type="int"/>
            <column name="parameter_mappings_json" type="text"/>
            <column name="visualization_settings_json" type="text"/>
            <column name="created_at" type="timestamp" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="analytics_dashboard_card"
            baseColumnNames="dashboard_id"
            referencedTableName="analytics_dashboard"
            referencedColumnNames="id"
            constraintName="fk_dashcard_dashboard"/>

        <addForeignKeyConstraint
            baseTableName="analytics_dashboard_card"
            baseColumnNames="card_id"
            referencedTableName="analytics_card"
            referencedColumnNames="id"
            constraintName="fk_dashcard_card"/>
    </changeSet>
</databaseChangeLog>

