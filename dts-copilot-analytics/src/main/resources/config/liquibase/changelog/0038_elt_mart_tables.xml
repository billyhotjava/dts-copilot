<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.22.xsd">

    <!-- ============================================================ -->
    <!-- EL-01: mart_project_fulfillment_daily                        -->
    <!-- 项目履约日维度宽表，每天每项目一行快照                         -->
    <!-- ============================================================ -->
    <changeSet id="0038-01-mart-project-fulfillment" author="sprint-11">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="mart_project_fulfillment_daily"/></not>
        </preConditions>
        <createTable tableName="mart_project_fulfillment_daily">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <!-- 维度 -->
            <column name="snapshot_date" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="project_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="project_name" type="varchar(256)"/>
            <column name="project_code" type="varchar(64)"/>
            <column name="project_status_name" type="varchar(16)"/>
            <column name="project_type_name" type="varchar(16)"/>
            <column name="customer_name" type="varchar(256)"/>
            <column name="contract_title" type="varchar(256)"/>
            <column name="settlement_type_name" type="varchar(32)"/>
            <column name="manager_name" type="varchar(128)"/>
            <column name="biz_user_name" type="varchar(128)"/>
            <column name="curing_director_name" type="varchar(128)"/>
            <!-- 库存度量（当日快照） -->
            <column name="green_count" type="int" defaultValueNumeric="0"/>
            <column name="position_count" type="int" defaultValueNumeric="0"/>
            <column name="total_monthly_rent" type="decimal(12,2)" defaultValueNumeric="0"/>
            <!-- 业务事件度量（当日增量） -->
            <column name="add_flower_count" type="int" defaultValueNumeric="0"/>
            <column name="change_flower_count" type="int" defaultValueNumeric="0"/>
            <column name="cut_flower_count" type="int" defaultValueNumeric="0"/>
            <column name="transfer_flower_count" type="int" defaultValueNumeric="0"/>
            <column name="add_flower_quantity" type="int" defaultValueNumeric="0"/>
            <column name="change_flower_quantity" type="int" defaultValueNumeric="0"/>
            <column name="cut_flower_quantity" type="int" defaultValueNumeric="0"/>
            <!-- 养护度量 -->
            <column name="curing_count" type="int" defaultValueNumeric="0"/>
            <column name="curing_positions" type="int" defaultValueNumeric="0"/>
            <!-- 任务度量 -->
            <column name="pending_task_count" type="int" defaultValueNumeric="0"/>
            <column name="completed_task_count" type="int" defaultValueNumeric="0"/>
            <!-- 结算度量（月级冗余） -->
            <column name="settlement_month" type="varchar(7)"/>
            <column name="monthly_receivable" type="decimal(12,2)" defaultValueNumeric="0"/>
            <column name="monthly_received" type="decimal(12,2)" defaultValueNumeric="0"/>
            <column name="monthly_outstanding" type="decimal(12,2)" defaultValueNumeric="0"/>
            <!-- 同步元数据 -->
            <column name="sync_batch_id" type="varchar(64)"/>
            <column name="synced_at" type="timestamp" defaultValueComputed="current_timestamp"/>
        </createTable>
        <addUniqueConstraint tableName="mart_project_fulfillment_daily"
                             columnNames="project_id, snapshot_date"
                             constraintName="uq_mart_pf_project_date"/>
        <createIndex tableName="mart_project_fulfillment_daily" indexName="idx_mart_pf_date">
            <column name="snapshot_date"/>
        </createIndex>
        <createIndex tableName="mart_project_fulfillment_daily" indexName="idx_mart_pf_project">
            <column name="project_id"/>
        </createIndex>
        <createIndex tableName="mart_project_fulfillment_daily" indexName="idx_mart_pf_customer">
            <column name="customer_name"/>
        </createIndex>
        <createIndex tableName="mart_project_fulfillment_daily" indexName="idx_mart_pf_month">
            <column name="settlement_month"/>
        </createIndex>
    </changeSet>

    <!-- ============================================================ -->
    <!-- EL-01: fact_field_operation_event                             -->
    <!-- 现场业务事件事实表，每条报花单据一行                          -->
    <!-- ============================================================ -->
    <changeSet id="0038-02-fact-field-operation" author="sprint-11">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="fact_field_operation_event"/></not>
        </preConditions>
        <createTable tableName="fact_field_operation_event">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="biz_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="biz_code" type="varchar(64)"/>
            <!-- 事件维度 -->
            <column name="event_date" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="event_month" type="varchar(7)">
                <constraints nullable="false"/>
            </column>
            <column name="event_year" type="int"/>
            <column name="biz_type_name" type="varchar(16)">
                <constraints nullable="false"/>
            </column>
            <column name="biz_status_name" type="varchar(16)">
                <constraints nullable="false"/>
            </column>
            <column name="is_urgent" type="varchar(4)"/>
            <!-- 项目维度 -->
            <column name="project_id" type="bigint"/>
            <column name="project_name" type="varchar(256)"/>
            <column name="customer_name" type="varchar(256)"/>
            <column name="manager_name" type="varchar(128)"/>
            <!-- 操作人维度 -->
            <column name="apply_user_name" type="varchar(128)"/>
            <column name="curing_user_name" type="varchar(128)"/>
            <column name="bear_cost_type_name" type="varchar(16)"/>
            <!-- 度量 -->
            <column name="plant_number" type="int" defaultValueNumeric="0"/>
            <column name="total_rent" type="decimal(12,2)" defaultValueNumeric="0"/>
            <column name="total_cost" type="decimal(12,2)" defaultValueNumeric="0"/>
            <!-- 时间戳 -->
            <column name="apply_time" type="timestamp"/>
            <column name="finish_time" type="timestamp"/>
            <!-- 同步元数据 -->
            <column name="source_updated_at" type="timestamp"/>
            <column name="sync_batch_id" type="varchar(64)"/>
            <column name="synced_at" type="timestamp" defaultValueComputed="current_timestamp"/>
        </createTable>
        <addUniqueConstraint tableName="fact_field_operation_event"
                             columnNames="biz_id"
                             constraintName="uq_fact_foe_biz_id"/>
        <createIndex tableName="fact_field_operation_event" indexName="idx_fact_foe_date">
            <column name="event_date"/>
        </createIndex>
        <createIndex tableName="fact_field_operation_event" indexName="idx_fact_foe_month">
            <column name="event_month"/>
        </createIndex>
        <createIndex tableName="fact_field_operation_event" indexName="idx_fact_foe_type">
            <column name="biz_type_name"/>
        </createIndex>
        <createIndex tableName="fact_field_operation_event" indexName="idx_fact_foe_project">
            <column name="project_name"/>
        </createIndex>
        <createIndex tableName="fact_field_operation_event" indexName="idx_fact_foe_watermark">
            <column name="source_updated_at"/>
        </createIndex>
    </changeSet>

    <!-- ============================================================ -->
    <!-- EL-01: elt_sync_watermark                                    -->
    <!-- 同步状态与 watermark 管理                                     -->
    <!-- ============================================================ -->
    <changeSet id="0038-03-elt-sync-watermark" author="sprint-11">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="elt_sync_watermark"/></not>
        </preConditions>
        <createTable tableName="elt_sync_watermark">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="target_table" type="varchar(128)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="last_watermark" type="timestamp"/>
            <column name="last_sync_time" type="timestamp"/>
            <column name="last_sync_rows" type="int" defaultValueNumeric="0"/>
            <column name="last_sync_duration_ms" type="int" defaultValueNumeric="0"/>
            <column name="sync_status" type="varchar(16)" defaultValue="IDLE"/>
            <column name="error_message" type="text"/>
            <column name="created_at" type="timestamp" defaultValueComputed="current_timestamp"/>
            <column name="updated_at" type="timestamp" defaultValueComputed="current_timestamp"/>
        </createTable>
    </changeSet>

    <changeSet id="0038-04-elt-watermark-seed" author="sprint-11">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT count(*) FROM elt_sync_watermark</sqlCheck>
        </preConditions>
        <insert tableName="elt_sync_watermark">
            <column name="target_table" value="mart_project_fulfillment_daily"/>
            <column name="sync_status" value="IDLE"/>
        </insert>
        <insert tableName="elt_sync_watermark">
            <column name="target_table" value="fact_field_operation_event"/>
            <column name="sync_status" value="IDLE"/>
        </insert>
    </changeSet>

</databaseChangeLog>
