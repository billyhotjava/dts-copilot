<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.22.xsd">

    <changeSet id="0003-01" author="codex">
        <createTable tableName="analytics_database">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="engine" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="details_json" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>
            <column name="is_sample" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="timezone" type="varchar(64)"/>
            <column name="metadata_sync_schedule" type="varchar(64)"/>
            <column name="cache_field_values_schedule" type="varchar(64)"/>
            <column name="auto_run_queries" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="is_full_sync" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="is_on_demand" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="${now}">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>

