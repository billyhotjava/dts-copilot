<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.22.xsd">

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- Batch 2: 7 fixed reports with real SQL backing                 -->
    <!-- ════════════════════════════════════════════════════════════════ -->

    <!-- 1. 报花单据汇总 -->
    <changeSet id="0047-01-flower-biz-doc-summary" author="dts">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(1) FROM analytics_report_template WHERE template_code = 'BIZ-FLOWER-DOC-SUMMARY'</sqlCheck>
        </preConditions>
        <insert tableName="analytics_report_template">
            <column name="template_code" value="BIZ-FLOWER-DOC-SUMMARY"/>
            <column name="name" value="报花单据汇总"/>
            <column name="description" value="对齐现网「统计报表→报花单据」页面，按项目点、业务类型、时间范围查看报花单据明细。"/>
            <column name="domain" value="报花"/>
            <column name="category" value="明细"/>
            <column name="data_source_type" value="SQL"/>
            <column name="target_object" value="authority.flowerbiz.biz_document_summary"/>
            <column name="refresh_policy" value="REALTIME"/>
            <column name="spec_json"><![CDATA[{"templateCode":"BIZ-FLOWER-DOC-SUMMARY","reportType":"fixed","displayType":"table","queryContract":{"sourceType":"AUTHORITY_SQL","targetObject":"authority.flowerbiz.biz_document_summary","databaseName":"园林业务库"},"placeholderReviewRequired":false}]]></column>
            <column name="parameter_schema_json"><![CDATA[{"params":[{"name":"projectId","label":"项目点","type":"text"},{"name":"bizType","label":"业务类型","type":"text"},{"name":"status","label":"状态","type":"text"},{"name":"startDate","label":"开始日期","type":"date"},{"name":"endDate","label":"结束日期","type":"date"}]}]]></column>
            <column name="metric_definition_json"><![CDATA[{"metrics":["单据数量"],"grain":"项目+业务类型+日期","owner":"报花管理"}]]></column>
        </insert>
    </changeSet>

