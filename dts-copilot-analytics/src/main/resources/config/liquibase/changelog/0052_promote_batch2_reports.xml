    <!-- 3. 日常报销 (FIN-REIMBURSEMENT-STATUS 已种入，更新为真实 backing) -->
    <changeSet id="0047-03-promote-reimbursement-list" author="dts">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="1">SELECT COUNT(1) FROM analytics_report_template WHERE template_code = 'FIN-REIMBURSEMENT-STATUS'</sqlCheck>
        </preConditions>
        <update tableName="analytics_report_template">
            <column name="name" value="日常报销"/>
            <column name="description" value="对齐现网「运营管理→日常报销」页面，按单号、状态、申请人查看报销明细。"/>
            <column name="target_object" value="authority.finance.reimbursement_list"/>
            <column name="spec_json"><![CDATA[{"templateCode":"FIN-REIMBURSEMENT-STATUS","reportType":"fixed","displayType":"table","queryContract":{"sourceType":"AUTHORITY_SQL","targetObject":"authority.finance.reimbursement_list","databaseName":"园林业务库"},"placeholderReviewRequired":false}]]></column>
            <column name="parameter_schema_json"><![CDATA[{"params":[{"name":"code","label":"单号","type":"text"},{"name":"status","label":"状态","type":"text"},{"name":"applyUserId","label":"申请人","type":"text"}]}]]></column>
            <where>template_code = 'FIN-REIMBURSEMENT-STATUS'</where>
        </update>
    </changeSet>

