  ('flowerbiz',  '["加花","换花","减花","调花","报花","坏账","售花","业务单","审批","驳回","审核","备货"]', 'v_flower_biz_detail', '[]', 0),
  ('green',      '["绿植","摆位","在摆","实摆","花盆","花架","摆放","盆栽"]', 'v_project_green_current', '["v_project_overview"]', 0),
  ('settlement', '["租金","应收","收款","欠款","结算","未结算","月租","账单","开票","收入","费用"]', 'v_monthly_settlement', '["v_project_overview"]', 0),
  ('task',       '["任务","待办","待处理","执行","完成率","进行中","日常任务"]', 'v_task_progress', '["v_pendulum_progress"]', 0),
  ('curing',     '["养护","养护人","巡检","覆盖率","养护记录","维护"]', 'v_curing_coverage', '[]', 0),
  ('pendulum',   '["初摆","首摆","新项目布置","预算","决算"]', 'v_pendulum_progress', '[]', 0);
        </sql>
    </changeSet>

</databaseChangeLog>
