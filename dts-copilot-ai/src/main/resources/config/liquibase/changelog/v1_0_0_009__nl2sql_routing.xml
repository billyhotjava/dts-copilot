<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- ============================================================ -->
    <!-- BG-07: nl2sql_routing_rule table                             -->
    <!-- ============================================================ -->
    <changeSet id="v1.0.0-009-nl2sql-routing-rule" author="dts-copilot">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists schemaName="copilot_ai" tableName="nl2sql_routing_rule"/>
            </not>
        </preConditions>
        <createTable schemaName="copilot_ai" tableName="nl2sql_routing_rule">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="domain" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="keywords" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="primary_view" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>
            <column name="secondary_views" type="TEXT"/>
            <column name="priority" type="INT" defaultValueNumeric="0"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="now()"/>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="now()"/>
        </createTable>
    </changeSet>

    <!-- ============================================================ -->
    <!-- BG-07: Seed routing rules                                    -->
    <!-- ============================================================ -->
    <changeSet id="v1.0.0-009-nl2sql-routing-seed" author="dts-copilot">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM copilot_ai.nl2sql_routing_rule
            </sqlCheck>
        </preConditions>

        <sql>
