<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- ============================================================ -->
    <!-- AA-06: AI audit log table                                    -->
    <!-- ============================================================ -->

    <changeSet id="v1.0.0-003-ai-audit-log" author="dts-copilot">
        <createTable tableName="ai_audit_log">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="VARCHAR(128)"/>
            <column name="session_id" type="VARCHAR(64)"/>
            <column name="action" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="tool_name" type="VARCHAR(64)"/>
            <column name="input" type="TEXT"/>
            <column name="output" type="TEXT"/>
            <column name="success" type="BOOLEAN"/>
            <column name="error_message" type="TEXT"/>
            <column name="duration_ms" type="BIGINT"/>
            <column name="metadata" type="JSONB"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()"/>
        </createTable>
    </changeSet>

    <changeSet id="v1.0.0-003-ai-audit-log-indexes" author="dts-copilot">
        <createIndex tableName="ai_audit_log" indexName="idx_ai_audit_log_user">
            <column name="user_id"/>
        </createIndex>
        <createIndex tableName="ai_audit_log" indexName="idx_ai_audit_log_session">
            <column name="session_id"/>
        </createIndex>
        <createIndex tableName="ai_audit_log" indexName="idx_ai_audit_log_created">
            <column name="created_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
