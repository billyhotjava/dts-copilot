# PostgreSQL
PG_HOST=copilot-postgres
PG_PORT=5432
PG_DB=copilot
PG_USER=copilot
PG_PASSWORD=copilot_dev

# Service ports
COPILOT_AI_PORT=8091
COPILOT_ANALYTICS_PORT=8092
COPILOT_WEBAPP_PORT=3003

# ── LLM 配置 ─────────────────────────────────────────────
# 默认使用公有云 LLM（DeepSeek 性价比最优）
# 可选: openai / deepseek / qwen / zhipu / ollama
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_API_KEY=              # ← 填入你的 API Key

# 如需使用其他公有云，取消注释对应行：
# --- OpenAI ---
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-xxx

# --- 通义千问 ---
# LLM_PROVIDER=qwen
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus
# LLM_API_KEY=sk-xxx

# --- 智谱GLM ---
# LLM_PROVIDER=zhipu
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4-flash
# LLM_API_KEY=xxx

# --- 本地 Ollama（需 --profile ollama 启动）---
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://copilot-ollama:11434/v1
# LLM_MODEL=qwen2.5-coder:7b
# LLM_API_KEY=

# TLS
TLS_PORT=443
HTTP_PORT=80
BASE_DOMAIN=copilot.local
COPILOT_TLS_ENABLED=true

# Admin
COPILOT_ADMIN_SECRET=change-me-in-production
