{
	"name": "@dts/copilot-webapp",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "VITE_CACHE_DIR=.vite-cache vite --host 0.0.0.0 --port 3003 --strictPort --open=false",
		"typecheck": "VITE_CACHE_DIR=.vite-cache tsc --noEmit",
		"prebuild": "pnpm validate:screen-plugins && pnpm validate:screen-plugin-boundary",
		"build": "VITE_CACHE_DIR=.vite-cache vite build",
		"analyze": "ANALYZE=1 VITE_CACHE_DIR=.vite-cache vite build",
		"preview": "vite preview --host 0.0.0.0 --port 3003 --strictPort",
		"scaffold:screen-plugin": "node scripts/scaffold-screen-plugin.mjs",
		"validate:screen-plugins": "node scripts/validate-screen-plugin-manifests.mjs",
		"validate:screen-plugin-boundary": "node scripts/validate-screen-plugin-boundary.mjs"
	},
	"dependencies": {
		"@ant-design/icons": "^5.6.1",
		"@jiaminghi/data-view-react": "^1.2.5",
		"antd": "^5.24.2",
		"echarts": "^6.0.0",
		"echarts-for-react": "^3.0.6",
		"echarts-wordcloud": "^2.1.0",
		"react": "^19.1.0",
		"react-dnd": "^16.0.1",
		"react-dnd-html5-backend": "^16.0.1",
		"react-dom": "^19.1.0",
		"react-grid-layout": "^1.5.0",
		"react-router": "^7.0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@types/node": "^24.12.0",
		"@types/react": "^19.0.12",
		"@types/react-dom": "^19.0.4",
		"@types/react-grid-layout": "^1.3.5",
		"@vitejs/plugin-react": "^4.3.3",
		"rollup-plugin-visualizer": "^7.0.1",
		"typescript": "^5.6.3",
		"vite": "^6.2.0"
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "pnpm@10.28.0",
	"browserslist": {
		"production": [
			"Chrome >= 120",
			"Edge >= 120"
		],
		"development": [
			"last 1 Chrome version"
		]
	}
}
